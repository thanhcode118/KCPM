		{
			"name": "GET /api/products?q=  Chair   (Tìm kiếm theo từ khóa thô, cắt khoảng trắng và không phân biệt chữ hoa thường)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code phải là 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Phải trả về danh sách và tất cả sản phẩm tìm thấy chứa từ khóa 'chair' (không phân biệt hoa thường)\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('items');",
							"    pm.expect(jsonData.items).to.be.an('array');",
							"    ",
							"    // Kiểm tra xem tất cả các sản phẩm trả về có chứa từ khóa 'chair' hay không (trong tên, SKU, brand, style, v.v.)",
							"    jsonData.items.forEach(function(item) {",
							"        var match = false;",
							"        var fields = [item.productName, item.sku, item.brand, item.style, item.material, item.color, item.category];",
							"        fields.forEach(function(field) {",
							"            if (field && field.toLowerCase().indexOf('chair') !== -1) {",
							"                match = true;",
							"            }",
							"        });",
							"        pm.expect(match, \"Sản phẩm ID \" + item.productId + \" phải khớp với từ khóa tìm kiếm\").to.be.true;",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{url}}/api/products?q=  Chair  ",
					"host": [
						"{{url}}"
					],
					"path": [
						"api",
						"products"
					],
					"query": [
						{
							"key": "q",
							"value": "  Chair  "
						}
					]
				}
			},
			"response": []
		},
