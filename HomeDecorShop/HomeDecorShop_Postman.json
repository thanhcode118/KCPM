{
	"info": {
		"_postman_id": "7bf3df87-a2f0-4a86-905c-d0c897f25e98",
		"name": "HomeDecorShop_Integration_Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "POST /api/auth/login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Kiem tra phan hoi tra ve ma 200 OK",
							"pm.test(\"Status code phải là 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Kiem tra phan hoi phai chua JWT Token bao mat",
							"pm.test(\"Phải trả về Token bảo mật\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('token');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"admin@homedecorshop.com\",\n    \"password\": \"AdminPassword123\"\n}"
				},
				"url": {
					"raw": "{{url}}/api/auth/login",
					"host": [
						"{{url}}"
					],
					"path": [
						"api",
						"auth",
						"login"
					]
				}
			},
			"response": []
		}
	]
}
